# Environment variables required for the Next.js application

# Node.js environment
NODE_ENV="development"

# PostgreSQL Database
# Example: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/pathfinder-ai"

# Google Gemini API
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Redis (Upstash)
REDIS_URL="redis://localhost:6379"
RATE_LIMIT_STORE="auto"
RATE_LIMIT_REDIS_PREFIX="pathfinder:rate-limit"
CACHE_STORE="auto"
CACHE_REDIS_PREFIX="pathfinder:cache"
CACHE_TTL_MS=600000

# Proxy configuration
TRUSTED_PROXY_COUNT=1

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/onboarding"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# Inngest
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# CORS
ALLOWED_ORIGINS=""
CORS_ORIGIN=""
